<?xml version="1.0" encoding="utf-8"?>
<IOLinkCatalog>

	<!--indirizzi IO di partenza per gli slave che andranno collegati sotto il master -->
	<IOLinkMasterModule>
		<Code>AL1102</Code>
		<MasterCopyName>AL1102</MasterCopyName>
		
		<InputStartAddresses>
			<Address>1000</Address>
			<Address>1300</Address>
			<Address>1600</Address>
			<Address>1900</Address>
			<!-- almeno 10 -->
		</InputStartAddresses>
		
		<OutputStartAddresses>
			<Address>1000</Address>
			<Address>1300</Address>
			<Address>1600</Address>
			<Address>1900</Address>
			<!-- almeno 10 -->
		</OutputStartAddresses>

		<IpAddresses> 
			<!--ip riferito solo all'ultimo ottetto in quanto la subnetwork potrebbe cambiare sul PLCStartupSettings.xml
			che comunque potrebbe subire un overwriting da interfaccia grafica-->
			<IPAddress>6</IPAddress>
			<IPAddress>7</IPAddress>
			<IPAddress>8</IPAddress>
			<IPAddress>9</IPAddress>
			<!-- almeno 10 -->
		</IpAddresses>

		<DeviceNumbers>
			<!--DeviceNumber = all'ultimo ottetto dell'indirizzo IP-->
			<DeviceNumber>6</DeviceNumber>
			<DeviceNumber>7</DeviceNumber>
			<DeviceNumber>8</DeviceNumber>
			<DeviceNumber>9</DeviceNumber>
			<!-- almeno 10 -->
		</DeviceNumbers>
		
	</IOLinkMasterModule>


</IOLinkCatalog>